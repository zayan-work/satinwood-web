# Cal.com booking link used by the homepage "Get started" section embed
# (free 15-minute discovery call). Format: "username/event-type".
# Copy this file to .env.local and set your real link.
NEXT_PUBLIC_CALCOM_LINK=satinwood/discovery

# Calendly slug for the /advisory page's PAID introductory call with Rengan
# ($150, charged at booking via Stripe inside Calendly). Format: "username/event-slug"
# taken from the live Calendly URL (calendly.com/<username>/<event-slug>).
# Leave the placeholder and the page shows a graceful "booking opens shortly" notice;
# set the real slug once the Calendly event + Stripe payment are live.
NEXT_PUBLIC_CALENDLY_LINK=REPLACE-WITH-RENGAN-EVENT
